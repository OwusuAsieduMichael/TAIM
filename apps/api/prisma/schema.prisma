generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL (Supabase "Transaction" pooler / port 6543) for the running API
  url       = env("DATABASE_URL")
  // Direct URL (Supabase "Session" / db host :5432) for `prisma migrate` and introspection
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  PARENT
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AssessmentType {
  CA
  EXAM
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model School {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  /// IANA timezone for school calendar, OTP windows, and attendance dates (e.g. Africa/Accra).
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  students               Student[]
  classes                Class[]
  subjects               Subject[]
  academicYears          AcademicYear[]
  notifications          Notification[]
  otpCodes               OtpCode[]
  auditLogs              AuditLog[]
  teacherWorkforceDays   TeacherWorkforceDay[]
  reportCardSubmissions  ReportCardSubmission[]
}

model User {
  id           String     @id @default(cuid())
  schoolId     String?
  school       School?    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  email        String?
  phone        String?
  passwordHash String?
  fullName     String
  role         Role
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  teacherSubjects TeacherSubject[]
  studentParents  StudentParent[]
  studentProfile  Student?         @relation("UserStudent")
  notifications   Notification[]
  auditLogs       AuditLog[]       @relation("AuditActor")
  attendanceMarks Attendance[]     @relation("AttendanceMarker")
  otpCodesForUser   OtpCode[]        @relation("OtpForUser")
  teacherWorkforceDays TeacherWorkforceDay[] @relation("TeacherWorkforce")
  reportCardsSubmitted ReportCardSubmission[] @relation("ReportCardTeacher")
  reportCardsReviewed  ReportCardSubmission[] @relation("ReportCardReviewer")

  @@unique([schoolId, email])
  @@unique([schoolId, phone])
  @@index([email])
}

model Student {
  id              String    @id @default(cuid())
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId          String    @unique
  user            User      @relation("UserStudent", fields: [userId], references: [id], onDelete: Cascade)
  admissionNumber String
  pinHash         String
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  gender          String?
  classId         String?
  class           Class?    @relation(fields: [classId], references: [id])
  /// Public HTTPS URL to passport-style portrait / photo (set by school admin).
  passportPhotoUrl String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parents    StudentParent[]
  attendance Attendance[]
  results    Result[]

  @@unique([schoolId, admissionNumber])
}

model StudentParent {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parentId  String
  parent    User    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  relation  String  @default("Guardian")

  @@unique([studentId, parentId])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  startsOn  DateTime
  endsOn    DateTime
  terms     Term[]
  classes   Class[]
  teacherSubjects TeacherSubject[]

  @@unique([schoolId, name])
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String
  order          Int
  startsOn       DateTime
  endsOn         DateTime
  results        Result[]
  assessments    Assessment[]
  reportCardSubmissions ReportCardSubmission[]

  @@unique([academicYearId, order])
}

model Class {
  id             String        @id @default(cuid())
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  name           String
  level          String?
  students       Student[]
  teacherSubjects TeacherSubject[]
  assessments    Assessment[]
  results        Result[]
  attendance              Attendance[]
  reportCardSubmissions     ReportCardSubmission[]

  @@unique([schoolId, name])
}

model Subject {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  teacherSubjects TeacherSubject[]
  assessments     Assessment[]
  results         Result[]

  @@unique([schoolId, name])
}

model TeacherSubject {
  id             String        @id @default(cuid())
  teacherId      String
  teacher        User          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId        String
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  @@unique([teacherId, subjectId, classId])
}

model Assessment {
  id        String           @id @default(cuid())
  termId    String
  term      Term             @relation(fields: [termId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId   String
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  name      String
  weight    Float
  type      AssessmentType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Result {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  termId     String
  term       Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  classId    String
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  caScore    Float    @default(0)
  examScore  Float    @default(0)
  finalScore Float    @default(0)
  grade      Int
  remark     String
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, subjectId, termId])
}

model Attendance {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus
  classId    String?
  class      Class?           @relation(fields: [classId], references: [id])
  markedById String?
  markedBy   User?            @relation("AttendanceMarker", fields: [markedById], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([studentId, date])
}

model Notification {
  id        String    @id @default(cuid())
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

model OtpCode {
  id         String    @id @default(cuid())
  schoolId   String?
  school     School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation("OtpForUser", fields: [userId], references: [id], onDelete: Cascade)
  phone      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose, consumedAt])
  @@index([userId, purpose, consumedAt])
}

/// Teacher workforce (sign-in / sign-out) for a school calendar day in `School.timezone`.
model TeacherWorkforceDay {
  id                String    @id @default(cuid())
  teacherId         String
  teacher           User      @relation("TeacherWorkforce", fields: [teacherId], references: [id], onDelete: Cascade)
  schoolId          String
  school            School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  localDate         String
  morningIssuedAt   DateTime?
  signInAt          DateTime?
  signInLate        Boolean   @default(false)
  eveningIssuedAt   DateTime?
  eveningDeadlineAt DateTime?
  signOutAt         DateTime?
  signOutLate       Boolean   @default(false)
  forcedLogoutAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([teacherId, localDate])
  @@index([schoolId, localDate])
}

enum ReportCardSubmissionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

/// Exam / term report card batch submitted by a teacher for admin approval before publish.
model ReportCardSubmission {
  id          String                     @id @default(cuid())
  schoolId    String
  school      School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User                       @relation("ReportCardTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  termId      String
  term        Term                       @relation(fields: [termId], references: [id], onDelete: Cascade)
  classId     String
  class       Class                      @relation(fields: [classId], references: [id], onDelete: Cascade)
  status      ReportCardSubmissionStatus @default(PENDING_APPROVAL)
  submittedAt DateTime                   @default(now())
  reviewedAt  DateTime?
  reviewerId  String?
  reviewer    User?                      @relation("ReportCardReviewer", fields: [reviewerId], references: [id])
  note        String?

  @@index([schoolId, termId, classId, status])
  @@index([teacherId, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}
