NODE_ENV=development
PORT=4000

# --- Supabase PostgreSQL (recommended) ---
# Project Settings → Database → Connection string (URI)
#
# DATABASE_URL = "Transaction pooler" (Session mode: Transaction)
#   Host looks like: aws-0-REGION.pooler.supabase.com  Port: 6543  (often has ?pgbouncer=true)
#
# DIRECT_URL — used by Prisma for migrate / db push / introspection (see schema `directUrl`)
#
# Option A — Direct (db host, port 5432). Fine on IPv6 or if you enabled Supabase IPv4 add-on.
#   Host: db.PROJECT_REF.supabase.co  Port: 5432
#
# Option B — If you get P1001 to db.*:5432 on Windows/home networks (IPv4-only), use Supavisor
#   SESSION mode on port 5432 (Dashboard → Connect → "Session pooler"). Prisma treats it like direct.
#   Host looks like: aws-0-REGION.pooler.supabase.com  Port: 5432
#   User often looks like: postgres.PROJECT_REF
#
# WRONG: db.xxx.supabase.co:6543  (mixing direct host with pooler port — Prisma will fail)
#
# Must include pgbouncer=true on the pooler URL or the API can hit prepared-statement errors.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use Option A (db host) or Option B (session pooler :5432) per comments above — not both at once.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
# Example Option B (session pooler — swap in your region, ref, password):
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Local PostgreSQL only ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taim?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/taim?schema=public"

JWT_SECRET="change-me-to-at-least-32-characters-long-secret"
JWT_EXPIRES_IN=24h
# Comma-separated. Include both if you open the app as localhost or 127.0.0.1.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=5
# Teacher workforce SMS OTP (set to 1 during local dev to skip sign-in gate on teacher APIs)
TEACHER_WORKFORCE_DISABLED=0
WORKFORCE_PUNCTUALITY_MINUTES=15
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=
